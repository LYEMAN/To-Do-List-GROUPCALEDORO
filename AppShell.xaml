<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiApp2.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiApp2"
    Title="To Do List">

    <ShellContent Title="Auth" ContentTemplate="{DataTemplate local:AuthPage}" Route="AuthPage" FlyoutItemIsVisible="False" />

    <TabBar x:Name="MainTabsTabBar" Route="MainTabs" FlyoutItemIsVisible="False">
        <ShellContent Title="To Do" Icon="dotnet_bot.svg" ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
        <ShellContent Title="Finished" Icon="check.svg" ContentTemplate="{DataTemplate local:FinishedPage}" Route="FinishedPage" />
    </TabBar>

</Shell>
