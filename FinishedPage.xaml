<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MauiApp2.FinishedPage"
    Title="Finished"
    BackgroundColor="#f7f8fa">

    <Grid RowDefinitions="auto,*">
        <!-- Header Section -->
        <Frame Grid.Row="0" BackgroundColor="#10b981" BorderColor="#10b981" CornerRadius="0" Padding="20" HasShadow="False" Margin="0">
            <Grid ColumnDefinitions="*,auto" RowDefinitions="auto,auto">
                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                    <Label Text="Completed Tasks" FontSize="24" FontAttributes="Bold" TextColor="#ffffff" />
                    <Label Text="Tasks you have marked done" FontSize="13" TextColor="#d1f3df" />
                </VerticalStackLayout>
                <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Text="↻ Refresh" Clicked="OnRefreshClicked" BackgroundColor="#ffffff" TextColor="#10b981" CornerRadius="8" VerticalOptions="Center" Padding="12,6" FontAttributes="Bold"/>
            </Grid>
        </Frame>

        <!-- Content Section - Scrollable -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="14" Padding="16">
                <CollectionView x:Name="finishedLV" SelectionMode="None" BackgroundColor="Transparent">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,6" Padding="14" CornerRadius="12" BackgroundColor="#ffffff" BorderColor="#e5e7eb" HasShadow="False">
                                <Grid RowDefinitions="auto,auto" ColumnDefinitions="*,auto" ColumnSpacing="10" RowSpacing="4">
                                    <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" FontSize="15" TextColor="#111827" LineBreakMode="WordWrap" />
                                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding Notes}" FontSize="13" TextColor="#6b7280" LineBreakMode="WordWrap" />
                                    <StackLayout Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                        <Button Text="↶" BackgroundColor="#2563eb" TextColor="White" CornerRadius="8" CommandParameter="{Binding ID}" Clicked="UndoToDoItem" Padding="12,8" FontAttributes="Bold" FontSize="16"/>
                                        <Button Text="×" BackgroundColor="#ef4444" TextColor="White" CornerRadius="8" CommandParameter="{Binding ID}" Clicked="DeleteToDoItem" Padding="12,8" FontAttributes="Bold" FontSize="18"/>
                                    </StackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Label x:Name="emptyLabel" Text="No completed tasks yet." FontSize="13" TextColor="#9ca3af" HorizontalOptions="Center" Margin="0,16" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>