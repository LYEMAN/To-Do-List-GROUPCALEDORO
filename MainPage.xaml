<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MauiApp2.MainPage"
    Title="To Do"
    BackgroundColor="#f7f8fa">

    <Grid RowDefinitions="auto,*">
        <!-- Header Section -->
        <Frame Grid.Row="0" BackgroundColor="#1f2937" BorderColor="#1f2937" CornerRadius="0" Margin="0" HasShadow="False">
            <Grid ColumnDefinitions="*,auto" RowDefinitions="auto,auto">
                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                    <Label Text="My Tasks" FontSize="24" FontAttributes="Bold" TextColor="#ffffff" />
                    <Label x:Name="userGreeting" Text="Welcome" FontSize="13" TextColor="#d1d5db" />
                </VerticalStackLayout>
                <StackLayout Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Spacing="8" VerticalOptions="Center">
                    <Button Text="↻ Refresh" Clicked="OnRefreshClicked" BackgroundColor="#ffffff" TextColor="#1f2937" CornerRadius="8" Padding="12,6" FontAttributes="Bold"/>
                    <Button Text="Logout" Clicked="OnLogoutClicked" BackgroundColor="#ef4444" TextColor="White" CornerRadius="8" Padding="12,6" FontAttributes="Bold"/>
                </StackLayout>
            </Grid>
        </Frame>

        <!-- Content Section - Scrollable -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="14" Padding="16">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Add a new task" FontSize="14" TextColor="#6b7280" FontAttributes="Bold" />
                    <Frame BackgroundColor="#ffffff" BorderColor="#e5e7eb" CornerRadius="12" Margin="0,0,0,0" HasShadow="False">
                        <VerticalStackLayout Spacing="10">
                            <Entry x:Name="titleEntry" Placeholder="Task title" BackgroundColor="#f9fafb" Margin="12,10" FontSize="14"/>
                            <Editor x:Name="detailsEditor" Placeholder="Details (optional)" HeightRequest="90" BackgroundColor="#f9fafb" Margin="12,10" FontSize="13"/>
                            <HorizontalStackLayout Spacing="8">
                                <Button x:Name="addBtn" Text="Add Task" Clicked="AddToDoItem" BackgroundColor="#111827" TextColor="White" CornerRadius="8" HorizontalOptions="Fill" FontAttributes="Bold"/>
                                <Button x:Name="editBtn" IsVisible="False" Text="Save Changes" Clicked="EditToDoItem" BackgroundColor="#2563eb" TextColor="White" CornerRadius="8" HorizontalOptions="Fill" FontAttributes="Bold"/>
                                <Button x:Name="cancelBtn" IsVisible="False" Text="Cancel" Clicked="CancelEdit" BackgroundColor="#e5e7eb" TextColor="#111827" CornerRadius="8" HorizontalOptions="Fill" FontAttributes="Bold"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Active Tasks" FontSize="14" TextColor="#6b7280" FontAttributes="Bold" />
                    <CollectionView x:Name="todoLV" SelectionMode="Single" SelectionChanged="TodoLV_OnItemSelected" BackgroundColor="Transparent">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,6" CornerRadius="12" BackgroundColor="#ffffff" BorderColor="#e5e7eb" HasShadow="False" Padding="14">
                                    <Grid ColumnDefinitions="*,auto,auto" RowDefinitions="auto,auto" ColumnSpacing="10" RowSpacing="4">
                                        <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" FontSize="15" TextColor="#111827" LineBreakMode="WordWrap" />
                                        <Label Grid.Row="1" Grid.Column="0" Text="{Binding Notes}" FontSize="13" TextColor="#6b7280" LineBreakMode="WordWrap" />
                                        <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Text="✓" BackgroundColor="#10b981" TextColor="White" CornerRadius="8" CommandParameter="{Binding ID}" Clicked="MarkDoneToDoItem" Padding="12,8" FontAttributes="Bold" VerticalOptions="Center" FontSize="16"/>
                                        <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Text="×" BackgroundColor="#ef4444" TextColor="White" CornerRadius="8" CommandParameter="{Binding ID}" Clicked="DeleteToDoItem" Padding="12,8" FontAttributes="Bold" VerticalOptions="Center" FontSize="18"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Label x:Name="emptyLabel" Text="No tasks yet. Add one to get started!" FontSize="13" TextColor="#9ca3af" HorizontalOptions="Center" Margin="0,16" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>