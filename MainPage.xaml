<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MauiApp2.MainPage"
    BackgroundColor="#f7f8fa">

    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="16">

            <Label Text="My Tasks" FontSize="26" FontAttributes="Bold" TextColor="#111827" />
            <Label Text="Add, edit, and delete tasks with a minimal interface." FontSize="13" TextColor="#6b7280" />

            <Frame BackgroundColor="#ffffff" BorderColor="#e5e7eb" CornerRadius="12" Padding="14" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Entry x:Name="titleEntry" Placeholder="Task title" BackgroundColor="#f9fafb" />
                    <Editor x:Name="detailsEditor" Placeholder="Details" HeightRequest="90" BackgroundColor="#f9fafb"/>
                    <HorizontalStackLayout Spacing="8">
                        <Button x:Name="addBtn" Text="Add" Clicked="AddToDoItem" BackgroundColor="#111827" TextColor="White" CornerRadius="8" HorizontalOptions="Fill"/>
                        <Button x:Name="editBtn" IsVisible="False" Text="Save" Clicked="EditToDoItem" BackgroundColor="#2563eb" TextColor="White" CornerRadius="8" HorizontalOptions="Fill"/>
                        <Button x:Name="cancelBtn" IsVisible="False" Text="Cancel" Clicked="CancelEdit" BackgroundColor="#e5e7eb" TextColor="#111827" CornerRadius="8" HorizontalOptions="Fill"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <CollectionView x:Name="todoLV" SelectionMode="Single" SelectionChanged="TodoLV_OnItemSelected" BackgroundColor="Transparent">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,4" Padding="12" CornerRadius="10" BackgroundColor="#ffffff" BorderColor="#e5e7eb" HasShadow="False">
                            <Grid ColumnDefinitions="*,auto" RowDefinitions="auto,auto">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="#111827" />
                                <Label Grid.Row="1" Grid.Column="0" Text="{Binding Notes}" FontSize="12" TextColor="#6b7280" />
                                <HorizontalStackLayout Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                    <Button Text="Done" BackgroundColor="#10b981" TextColor="White" CornerRadius="6" CommandParameter="{Binding ID}" Clicked="MarkDoneItem" Padding="10,6"/>
                                    <Button Text="Delete" BackgroundColor="#ef4444" TextColor="White" CornerRadius="6" CommandParameter="{Binding ID}" Clicked="DeleteToDoItem" Padding="10,6"/>
                                </HorizontalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>