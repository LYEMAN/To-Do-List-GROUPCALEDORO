<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MauiApp2.AuthPage"
    Title="Authentication">

    <VerticalStackLayout Spacing="12" Padding="20">

        <Label Text="Welcome" FontSize="24" HorizontalOptions="Center" />

        <Entry x:Name="usernameEntry" Placeholder="Username" />
        <Entry x:Name="passwordEntry" Placeholder="Password" IsPassword="True" />

        <Label x:Name="messageLabel" TextColor="Red" HorizontalOptions="Center" />

        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
            <Button Text="Login" Clicked="OnLoginClicked" />
            <Button Text="Sign Up" Clicked="OnSignUpClicked" />
        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>
